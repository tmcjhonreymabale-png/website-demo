    <?php if ($success): ?>
        <div class="alert alert-success">
            <span class="material-icons">check_circle</span>
            <span><?php echo $success; ?></span>
        </div>
    <?php endif; ?>

    <!-- Scanner and Manual Entry -->
    <div class="scanner-container">
        <!-- QR Scanner (Simulated) -->
        <div class="scanner-section">
            <div class="scanner-header">
                <h2>
                    <span class="material-icons">qr_code_scanner</span>
                    QR Code Scanner
                </h2>
            </div>
            <div class="scanner-body">
                <div class="scanner-preview" id="scanner-preview">
                    <div class="scanner-placeholder">
                        <span class="material-icons">camera_alt</span>
                        <h3>Camera Scanner</h3>
                        <p>Click "Simulate Scan" to test QR scanning</p>
                    </div>
                </div>
                
                <div class="scanner-controls">
                    <button onclick="simulateScan()" class="btn-simulate">
                        <span class="material-icons">qr_code_scanner</span>
                        Simulate Scan
                    </button>
                </div>
                
                <div class="scanner-note">
                    <span class="material-icons">info</span>
                    <span>For testing: Click "Simulate Scan" and enter a resident ID (e.g., 1, 2, 3)</span>
                </div>
            </div>
        </div>

        <!-- Manual Entry -->
        <div class="manual-entry">
            <div class="manual-header">
                <h2>
                    <span class="material-icons">keyboard</span>
                    Manual Entry
                </h2>
            </div>
            <div class="manual-body">
                <form method="POST" class="manual-form">
                    <div class="form-group">
                        <label for="qr_input">Enter QR Code Data or Resident ID</label>
