<?php
// admin/qr/scan.php

// Start session first
if (session_status() === PHP_SESSION_NONE) {
    session_start();
}

require_once '../../config/database.php';

// Check if admin is logged in
if (!isset($_SESSION['admin_id'])) {
    header('Location: ../login.php');
    exit();
}

$database = new Database();
$db = $database->getConnection();

// Create qr_codes table if it doesn't exist
$create_table = "CREATE TABLE IF NOT EXISTS qr_codes (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT UNIQUE,
    qr_code_data VARCHAR(255) UNIQUE,
    qr_code_image VARCHAR(255),
    generated_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    expires_date DATE,
    is_active BOOLEAN DEFAULT TRUE,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
)";
$db->exec($create_table);

$scan_result = null;
$error = '';
$success = '';

// Handle QR code generation
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['generate_qr'])) {
    $user_id = $_POST['user_id'];
    
    // Check if user exists
    $user_query = "SELECT id, first_name, last_name FROM users WHERE id = :id AND user_type = 'resident'";
    $user_stmt = $db->prepare($user_query);
    $user_stmt->bindParam(':id', $user_id);
    $user_stmt->execute();
    $user = $user_stmt->fetch(PDO::FETCH_ASSOC);
    
    if ($user) {
        // Generate unique QR code data
        $qr_data = "BARANGAY-RESIDENT-" . str_pad($user_id, 6, '0', STR_PAD_LEFT) . "-" . date('Ymd') . "-" . uniqid();
        $expires_date = date('Y-m-d', strtotime('+1 year'));
        
        // Check if QR code already exists
        $check_query = "SELECT id FROM qr_codes WHERE user_id = :user_id";
        $check_stmt = $db->prepare($check_query);
        $check_stmt->bindParam(':user_id', $user_id);
        $check_stmt->execute();
        
        if ($check_stmt->rowCount() > 0) {
            // Update existing QR code
            $update_query = "UPDATE qr_codes SET qr_code_data = :data, expires_date = :expires, generated_date = NOW(), is_active = 1 WHERE user_id = :user_id";
            $update_stmt = $db->prepare($update_query);
            $update_stmt->bindParam(':data', $qr_data);
            $update_stmt->bindParam(':expires', $expires_date);
            $update_stmt->bindParam(':user_id', $user_id);
            $update_stmt->execute();
        } else {
            // Create new QR code
            $insert_query = "INSERT INTO qr_codes (user_id, qr_code_data, expires_date) VALUES (:user_id, :data, :expires)";
            $insert_stmt = $db->prepare($insert_query);
            $insert_stmt->bindParam(':user_id', $user_id);
            $insert_stmt->bindParam(':data', $qr_data);
            $insert_stmt->bindParam(':expires', $expires_date);
            $insert_stmt->execute();
        }
        
        // Log the action
        try {
            $log_query = "INSERT INTO admin_logs (admin_id, action, description, ip_address) 
                          VALUES (:admin_id, 'GENERATE_QR', :desc, :ip)";
            $log_stmt = $db->prepare($log_query);
            $desc = "Generated QR code for resident: " . $user['first_name'] . " " . $user['last_name'];
            $ip = $_SERVER['REMOTE_ADDR'] ?? '127.0.0.1';
            $log_stmt->bindParam(':admin_id', $_SESSION['admin_id']);
            $log_stmt->bindParam(':desc', $desc);
            $log_stmt->bindParam(':ip', $ip);
            $log_stmt->execute();
        } catch (Exception $e) {
            // Log table might not exist
        }
        
        $_SESSION['success'] = "QR Code generated successfully for " . $user['first_name'] . " " . $user['last_name'];
        header('Location: scan.php');
        exit();
    } else {
        $error = "Resident not found";
    }
}

// Handle QR code scan (manual entry)
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['scan_qr'])) {
    $qr_input = trim($_POST['qr_input']);
    
    if (empty($qr_input)) {
        $error = "Please enter QR code data";
    } else {
        // Try to find by QR code data
        $qr_query = "SELECT user_id FROM qr_codes WHERE qr_code_data = :data AND is_active = 1 AND (expires_date IS NULL OR expires_date >= CURDATE())";
        $qr_stmt = $db->prepare($qr_query);
        $qr_stmt->bindParam(':data', $qr_input);
        $qr_stmt->execute();
        $qr_result = $qr_stmt->fetch(PDO::FETCH_ASSOC);
        
        $user_id = null;
        
        if ($qr_result) {
            $user_id = $qr_result['user_id'];
        } else {
            // Try to extract user ID from format BARANGAY-RESIDENT-XXXXXX-...
            if (preg_match('/BARANGAY-RESIDENT-(\d+)/', $qr_input, $matches)) {
                $user_id = intval($matches[1]);
            } else {
                // Try direct user ID
                $user_id = intval($qr_input);
            }
        }
        
        if ($user_id) {
            // Get resident details
            $query = "SELECT u.*, ri.* 
                      FROM users u
                      LEFT JOIN resident_info ri ON u.id = ri.user_id
                      WHERE u.id = :id AND u.user_type = 'resident'";
            $stmt = $db->prepare($query);
            $stmt->bindParam(':id', $user_id);
            $stmt->execute();
            $scan_result = $stmt->fetch(PDO::FETCH_ASSOC);
            
            if ($scan_result) {
                // Log the scan
                try {
                    $log_query = "INSERT INTO admin_logs (admin_id, action, description, ip_address) 
                                  VALUES (:admin_id, 'QR_SCAN', :desc, :ip)";
                    $log_stmt = $db->prepare($log_query);
                    $desc = "Scanned QR code for resident: " . ($scan_result['first_name'] ?? '') . " " . ($scan_result['last_name'] ?? '');
                    $ip = $_SERVER['REMOTE_ADDR'] ?? '127.0.0.1';
                    $log_stmt->bindParam(':admin_id', $_SESSION['admin_id']);
                    $log_stmt->bindParam(':desc', $desc);
                    $log_stmt->bindParam(':ip', $ip);
                    $log_stmt->execute();
                } catch (Exception $e) {
                    // Log table might not exist
                }
                
                $success = "Resident found successfully!";
            } else {
                $error = "Resident not found";
            }
        } else {
            $error = "Invalid QR code or resident not found";
        }
    }
}

// Get all residents for QR generation dropdown
$residents_query = "SELECT id, first_name, last_name FROM users WHERE user_type = 'resident' ORDER BY last_name, first_name";
$residents_stmt = $db->query($residents_query);
$residents = $residents_stmt->fetchAll(PDO::FETCH_ASSOC);

// Get recent QR codes
$recent_query = "SELECT q.*, u.first_name, u.last_name 
                 FROM qr_codes q
                 JOIN users u ON q.user_id = u.id
                 ORDER BY q.generated_date DESC LIMIT 10";
$recent_stmt = $db->query($recent_query);
$recent_qrs = $recent_stmt->fetchAll(PDO::FETCH_ASSOC);

include '../includes/admin_header.php';
?>

<style>
/* ===== QR SCANNER STYLES ===== */
.qr-module {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem;
}

/* Header */
.module-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
}

.module-title h1 {
    font-size: 1.8rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 0.25rem;
}

.module-title p {
    color: #64748b;
    font-size: 0.95rem;
}

/* Alerts */
.alert {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    margin-bottom: 1.5rem;
    border-radius: 8px;
    animation: slideIn 0.3s ease;
}

.alert-success {
    background: #dcfce7;
    color: #166534;
    border-left: 4px solid #22c55e;
}

.alert-danger {
    background: #fee2e2;
    color: #991b1b;
    border-left: 4px solid #ef4444;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Scanner Container */
.scanner-container {
    display: grid;
